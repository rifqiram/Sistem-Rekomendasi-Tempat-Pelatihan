{
  "info": {
    "name": "SIREKPEL API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "token", "value": "admintoken" },
    { "key": "peserta_id", "value": "1" },
    { "key": "pelatihan_id", "value": "1" },
    { "key": "kategori_id", "value": "1" },
    { "key": "keahlian_id", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"User SIREKPEL\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}" },
            "url": "{{base_url}}/api/register"
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "if (json.data && json.data.token) {", "  pm.collectionVariables.set('token', json.data.token);", "  pm.environment.set('token', json.data.token);", "}"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password\"\n}" },
            "url": "{{base_url}}/api/login"
          }
        },
        { "name": "Me", "request": { "method": "GET", "url": "{{base_url}}/api/me" } },
        { "name": "Logout", "request": { "method": "POST", "url": "{{base_url}}/api/logout" } }
      ]
    },
    {
      "name": "Master Data",
      "item": [
        { "name": "List Kategori", "request": { "method": "GET", "url": "{{base_url}}/api/kategori" } },
        { "name": "Create Kategori", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"nama\": \"Teknologi\",\n  \"deskripsi\": \"Kategori teknologi\"\n}" }, "url": "{{base_url}}/api/kategori" } },
        { "name": "List Keahlian", "request": { "method": "GET", "url": "{{base_url}}/api/keahlian" } },
        { "name": "Create Keahlian", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"kategori_id\": {{kategori_id}},\n  \"nama\": \"Laravel\",\n  \"deskripsi\": \"Framework PHP\"\n}" }, "url": "{{base_url}}/api/keahlian" } }
      ]
    },
    {
      "name": "Pelatihan",
      "item": [
        { "name": "List Pelatihan", "request": { "method": "GET", "url": "{{base_url}}/api/pelatihan" } },
        { "name": "Create Pelatihan", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"judul\": \"Pelatihan Laravel\",\n  \"deskripsi\": \"Belajar Laravel API\",\n  \"kategori\": \"Teknologi\",\n  \"level\": \"Pemula\",\n  \"durasi\": \"3 Hari\",\n  \"sertifikat\": \"Ya\",\n  \"tanggal_mulai\": \"2026-07-01\",\n  \"tanggal_selesai\": \"2026-07-03\",\n  \"is_active\": true,\n  \"keahlian_ids\": [{{keahlian_id}}]\n}" }, "url": "{{base_url}}/api/pelatihan" } },
        { "name": "Detail Pelatihan", "request": { "method": "GET", "url": "{{base_url}}/api/pelatihan/{{pelatihan_id}}" } },
        { "name": "Daftar Pelatihan", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"peserta_id\": {{peserta_id}}\n}" }, "url": "{{base_url}}/api/pelatihan/{{pelatihan_id}}/pendaftaran" } }
      ]
    },
    {
      "name": "Peserta & Rekomendasi",
      "item": [
        { "name": "Create Peserta", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"nama\": \"Peserta Satu\",\n  \"email\": \"peserta@example.com\",\n  \"telepon\": \"08123456789\",\n  \"keahlian\": \"PHP\"\n}" }, "url": "{{base_url}}/api/peserta" } },
        { "name": "Set Keahlian Peserta", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"keahlian\": [\n    { \"id\": {{keahlian_id}}, \"level\": \"Dasar\" }\n  ]\n}" }, "url": "{{base_url}}/api/peserta/{{peserta_id}}/keahlian" } },
        { "name": "Riwayat Peserta", "request": { "method": "GET", "url": "{{base_url}}/api/peserta/{{peserta_id}}/riwayat" } },
        { "name": "Rekomendasi", "request": { "method": "GET", "url": "{{base_url}}/api/rekomendasi?peserta_id={{peserta_id}}" } }
      ]
    }
  ]
}
